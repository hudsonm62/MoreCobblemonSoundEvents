{
    "schemaVersion": 1,
    "id": "morecobblemonsoundevents",
    "version": "${version}",
    "name": "More Cobblemon Sound Events",
    "description": "Adds a collection of extra Cobblemon sound events, making it easier for resourcepack and modpack creators to customise audio.",
    "authors": ["Hudson M."],
    "contact": {
        "homepage": "https://modrinth.com/mod/morecobblemonsoundevents",
        "sources": "https://github.com/hudsonm62/MoreCobblemonSoundEvents",
        "issues": "https://github.com/hudsonm62/MoreCobblemonSoundEvents/issues"
    },
    "license": "Apache License 2.0",
    "icon": "assets/morecobblemonsoundevents/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            {
                "value": "com.ziroau.morecobblemonsoundevents.MoreCobblemonSoundEvents",
                "adapter": "kotlin"
            }
        ]
    },
    "depends": {
        "fabricloader": ">=0.19.2",
        "minecraft": "~1.21.1",
        "java": ">=21",
        "cobblemon": ">=1.7.0",
        "fabric-api": "*",
        "fabric-language-kotlin": "*"
    }
}
