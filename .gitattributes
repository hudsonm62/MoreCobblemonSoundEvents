# Default git behavior
* text=auto

### OVERRIDES ###

# CRLF => LF
.prettierrc      text  eol=lf
.prettierignore  text  eol=lf
*.md             text  eol=lf
*.gitattributes  text  eol=lf
*.gitmodules     text  eol=lf
*.gitignore      text  eol=lf
*.yml            text  eol=lf
*.json           text  eol=lf
*.properties     text  eol=lf
*.mcmeta         text  eol=lf
**/LICENSE       text  eol=lf
**/CODEOWNERS    text  eol=lf

### Gradle
**/*.gradle      text eol=lf
**/gradlew       text eol=lf
*.bat            text eol=crlf

### Java / Kotlin
**/*.java        text eol=lf
**/*.kt          text eol=lf
